# Copy to carillon.env (chmod 600). These are secrets — keep them out of git.
# Loaded into the Carillon run container via EnvironmentFile in carillon.container.

# Public-read-only GitHub token (no-scope classic PAT or fine-grained
# "Public Repositories" read-only). Raises the rate limit 60 -> 5,000 req/hr.
CARILLON_CRED_GITHUB=

# Mattermost incoming-webhook URL. Leave empty to run in log-only mode
# (new releases are logged instead of posted).
CARILLON_MM_DEFAULT=
